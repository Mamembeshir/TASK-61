# Copy this file to .env and fill in values before running.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
DB_NAME=harborops
DB_USER=harborops
DB_PASSWORD=harborops
DB_HOST=127.0.0.1
DB_PORT=3306
DB_ROOT_PASSWORD=rootpassword

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Encryption
# Generate with:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# ---------------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# File uploads
# ---------------------------------------------------------------------------
UPLOAD_ROOT=/var/harborops/uploads/
MAX_UPLOAD_MB=25

# ---------------------------------------------------------------------------
# Auth / lockout
# ---------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
SESSION_COOKIE_AGE=28800

# ---------------------------------------------------------------------------
# Password policy
# ---------------------------------------------------------------------------
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRY_DAYS=90

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
SITE_TIMEZONE_DEFAULT=America/New_York

# ---------------------------------------------------------------------------
# Webhooks / Celery retries
# ---------------------------------------------------------------------------
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_COUNTDOWN_SECONDS=200

# ---------------------------------------------------------------------------
# Bulk import limits
# ---------------------------------------------------------------------------
BULK_IMPORT_MAX_FILE_MB=25
BULK_IMPORT_MAX_ROWS=10000

# ---------------------------------------------------------------------------
# Analytics
# ---------------------------------------------------------------------------
ANALYTICS_REFRESH_MINUTES=15
AUDIT_LOG_RETENTION_YEARS=7

# ---------------------------------------------------------------------------
# CORS (React dev server)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173 http://127.0.0.1:5173
