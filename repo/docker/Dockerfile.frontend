FROM node:20-alpine

WORKDIR /app

# Install dependencies first (layer cache)
COPY package.json package-lock.json* yarn.lock* ./
RUN npm install

COPY . .

EXPOSE 5173

# host: "0.0.0.0" is set in vite.config.ts so the port is reachable from the host
# Run npm install at startup so the anonymous node_modules volume is always
# in sync with package.json, even after packages are added without rebuilding.
CMD ["sh", "-c", "npm install && npm run dev"]
